[Unit]
Description=WhatsApp follow-up listener (capture + daily reminders + ack delivery)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=appuser
WorkingDirectory=/opt/wa-app
EnvironmentFile=/opt/wa-app/.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm run start:listener
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
