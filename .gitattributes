# Normalize all text to LF in the repo and on checkout. Critical for the Linux
# deploy: CRLF would break bash scripts (`$'\r'`) and cloud-init/systemd units.
* text=auto eol=lf
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.service text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
