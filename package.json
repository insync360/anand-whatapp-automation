{
  "name": "whatsapp-followup-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-user, self-hosted WhatsApp follow-up assistant (read-only listener, Telegram reminders).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "start:listener": "tsx src/listener.ts",
    "seed": "tsx scripts/seed-inbox.ts",
    "start:worker": "tsx src/worker.ts",
    "remind:now": "tsx scripts/remind-now.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "pg": "^8.21.0",
    "pino": "^9.6.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/qrcode-terminal": "^0.12.2",
    "pg-mem": "^3.0.14",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
